# 飞书应用凭证（在飞书开放平台 → 应用管理 → 凭证与基础信息中获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 常用审批类型映射（可选，JSON 格式，从审批管理后台 URL 中获取 definitionCode）
# FEISHU_APPROVAL_CODES='{"\u8bf7\u5047":"CODE1","\u52a0\u73ed":"CODE2","\u51fa\u5dee":"CODE3"}'

# 服务端口（可选，默认 8002）
PORT=8002
